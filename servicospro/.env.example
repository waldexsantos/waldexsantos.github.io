# ── Copie este arquivo para .env.local e preencha ──────────────

# Connection string do Neon (pegue no console.neon.tech → Connection Details)
DATABASE_URL=postgresql://user:senha@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Segredo para assinar os JWTs — coloque qualquer string longa e aleatória
JWT_SECRET=troque_por_uma_string_secreta_longa_aqui_12345
